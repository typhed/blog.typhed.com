# ---------------------------------------------------------------------------
# Analytics & monetization
#
# All values are optional. Each feature renders nothing until its id is set, so
# local/dev builds stay untracked. These are NEXT_PUBLIC_* values that ship to
# the browser — they are NOT secrets. In CI, set them as GitHub Actions
# repository *Variables* (Settings -> Secrets and variables -> Actions ->
# Variables), not Secrets. Locally, copy this file to `.env.local` and fill in
# only what you use.
# ---------------------------------------------------------------------------

# Google Analytics 4 measurement id, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google AdSense publisher id, e.g. ca-pub-0000000000000000
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Microsoft Clarity project id, e.g. abcdefghij
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Google Search Console HTML-tag verification token — the value of the
# content="..." attribute Google gives you. Alternatively verify via DNS TXT or
# an uploaded HTML file (see setup.md); leave this blank if you do.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Clerk publishable key for freemium sign-in, e.g. pk_live_xxxxxxxxxxxx. Use the
# SAME key as the main typhed.com site so a session is shared across the two
# subdomains. Leave blank to disable auth: freemium posts then render ungated.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
